<odoo>
    <template id="custom_header_invoice">
        <style>
            .only-bottom {
                border-bottom: 1px solid;
                border-top: none;
                border-left: none;
                border-right: none;
            }
            .only-right {
                border-bottom: none;
                border-top: none;
                border-left: none;
                border-right: 1px solid black;
            }
        </style>

        <div style="border-color: black !important; border: 1px solid;">
            <div class="row" style="position: relative;">
                <div class="col-6 only-right">
                    <div class="row border-top-0" style="font-family:sans-serif">
                        <div class="col-3">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" class="m-2 p-2" alt="Logo" style="width:100px;"/>
                        </div>
                        <div class="col-8 text-start" style="color: black !important;">
                            <strong><div t-field="o.company_id.company_details"/></strong>
                        </div>
                    </div>
                </div>
                <div class="col border-top-0" style="position: absolute; left: 46.75%; background-color: white; top: 1px; width: 62px; height: 64px; border-color: black !important; border: 1px solid;">
                    <table name="hito-center-upper" class="table-borderless" style="text-align: center; margin: auto;">
                        <tr>
                            <td>
                                <h2 style="margin: 0; color: black;">
                                    <strong><span t-out="document_letter or '&#160;'"/></strong>
                                </h2>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <span style="font-size: x-small;" t-out="document_legend or '&#160;'"/>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-6" style="margin-left:50px; text-align: start; font-family:sans-serif;">
                    <span t-field="o.l10n_latam_document_type_id.name" style="font-weight:bold; font-size: 22px;"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Pago en C.B.U informada.</span>
                    <br/>
                    <t t-if="o.state == posted">
                        <span style="font-weight:bold; font-size: 18px;">Punto de venta: </span><span t-esc="o.sequence_prefix[4:10]"/>   <span style="font-weight:bold; font-size: 18px;">Comp. N°: </span><span style="font-size: 18px;" t-esc="o.l10n_latam_document_number.split('-')[1]"/>
                        <br/>
                    </t>
                    <t t-else="">
                        <span><span style="font-weight:bold; font-size: 18px;">Punto de venta:      </span>   <strong>Comp. N°:</strong></span>
                        <br/>
                    </t>
                    <span style="font-weight:bold; font-size: 18px;">Fecha de Emisión: </span><span t-field="o.invoice_date"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">CUIT: </span><span t-field="o.company_id.vat"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Ingresos Brutos: </span><span t-out="o.company_id.l10n_ar_gross_income_type == 'exempt' and 'Exento' or o.company_id.l10n_ar_gross_income_number"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Fecha de Inicio de Actividades: </span><span t-field="o.company_id.l10n_ar_afip_start_date"/>
                </div>
            </div>
        </div>

    </template>

    <template id="l10n_ar.report_invoice_document" inherit_id="account.report_invoice_document">
              <!-- custom header and footer -->
        <t t-set="o" position="after">
            <t t-set="custom_header" t-value="'hito_emu_custom_reports.custom_header_invoice'"/>
            <t t-set="report_date" t-value="o.invoice_date"/>
            <t t-set="report_number" t-value="o.l10n_latam_document_number"/>
            <t t-set="pre_printed_report" t-value="report_type == 'pdf' and o.journal_id.l10n_ar_afip_pos_system == 'II_IM'"/>
            <t t-set="document_letter" t-value="o.l10n_latam_document_type_id.l10n_ar_letter"/>
            <t t-set="document_legend" t-value="o.l10n_latam_document_type_id.code and 'Cod. %02d' % int(o.l10n_latam_document_type_id.code) or ''"/>
            <t t-set="report_name" t-value="o.l10n_latam_document_type_id.report_name"/>
            <t t-set="header_address" t-value="o.journal_id.l10n_ar_afip_pos_partner_id"/>

            <t t-set="custom_footer">
                <table class="table table-bordered w-100 mb-0" style="border: 1px solid black; border-collapse: collapse; table-layout: fixed;">
                    <tr>
                        <td class="p-2" style="border: 1px solid black; width:70%; vertical-align: top;" rowspan="4">
                            <strong>NOTA:</strong>
                            <br/>
                            <span t-field="o.internal_notes"/>
                        </td>

                        <td class="p-2" style="border: 1px solid black; width:30%; height:12px; vertical-align: middle; font-size:14px;">
                            <strong>Gravado:</strong>
                            <span t-field="o.amount_untaxed" class="float-end"/>
                        </td>
                    </tr>
                    <tr>
                        <td class="p-2" style="border: 1px solid black; height:12px; vertical-align: middle;">

                        </td>
                    </tr>
                    <tr>
                        <td class="p-2" style="border: 1px solid black; height:12px; vertical-align: middle; font-size:14px;">
                            <strong>Moneda: </strong> <span t-field="o.currency_id.currency_unit_label"/>
                        </td>
                    </tr>
                    <tr>
                        <td class="p-2" style="border: 1px solid black;height:12px; vertical-align: middle;">

                        </td>
                    </tr>
                </table>

                <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                <t t-set="iibb_caba" t-value="0"/>
                <t t-set="iibb_arba" t-value="0"/>
                <t t-set="iva" t-value="0"/>

                <t t-foreach="lines" t-as="line">
                    <t t-foreach="line.tax_ids" t-as="tax">

                        <t t-if="tax.l10n_ar_tribute_afip_code == '07' and tax.l10n_ar_state_code == 'C'">
                            <t t-set="iibb_caba" t-value="iibb_caba + line.price_total - line.price_subtotal"/>
                        </t>

                        <t t-if="tax.l10n_ar_tribute_afip_code == '07' and tax.l10n_ar_state_code == 'B'">
                            <t t-set="iibb_arba" t-value="iibb_arba + line.price_total - line.price_subtotal"/>
                        </t>

                        <t t-if="'IVA' in tax.tax_group_id.name">
                            <t t-set="iva" t-value="iva + line.price_total - line.price_subtotal"/>
                        </t>
                    </t>
                </t>


                <table class="table table-bordered w-100 mt-1" style="border: 1px solid black; border-collapse: collapse; table-layout: fixed;">
                    <tr>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:12px;">
                            <span style="font-size:14px;">Subtotal</span>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:12px;">
                            <t t-if="iibb_arba">
                                <span style="font-size:14px;">Percep.IB.ARBA</span>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:12px;">
                            <t t-if="iibb_caba">
                                <span style="font-size:14px;">Percep.IB.CABA</span>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14% height:12px;;">
                            <t t-if="iva">
                                <span style="font-size:14px;">IVA</span>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:12px;">

                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:15%; height:12px;">

                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:15%; height:12px;">
                            <span style="font-size:14px;">TOTAL</span>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:14px;">
                            <span style="font-size:14px;" t-esc="'{:,.2f}'.format(o.amount_untaxed)"/>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:14px;">
                            <t t-if="iibb_arba">
                                <span style="font-size:14px;" t-esc="'{:,.2f}'.format(iibb_arba)"/>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:14px;">
                             <t t-if="iibb_caba">
                                <span style="font-size:14px;" t-esc="'{:,.2f}'.format(iibb_caba)"/>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:14px;">
                             <t t-if="iva">
                                <span style="font-size:14px;" t-esc="'{:,.2f}'.format(iva)"/>
                            </t>
                        </td>
                        <td class="text-center p-1" style="border: 1px solid black; width:14%; height:14px;"/>
                        <td class="text-center p-1" style="border: 1px solid black; width:15%; height:14px;"/>
                        <td class="text-center p-1" style="border: 1px solid black; width:15%; height:14px;">
                            <span style="font-size:14px;" t-esc="'{:,.2f}'.format(o.amount_total)"/>
                        </td>
                    </tr>
                </table>
                <div class="p-2" style="border: 1px solid black; height:110px;">
                    <span>Observaciones</span> <span t-field="o.narration"/>
                </div>

                <div class="row">
                    <div name="footer_left_column" class="col-8 text-start">
                        <span t-field="o.invoice_code" style="font-size:22px;"/>
                        <br/>
                        <t t-if="not copy_type">
                            <span>ORIGINAL</span>
                            <br/>
                        </t>
                        <t t-if="copy_type">
                            <t t-out="copy_type"/>
                            <br/>
                        </t>
                    </div>
                    <div name="footer_right_column" class="col-4 text-end">
                        <div name="pager" t-if="report_type == 'pdf'">
                            Page: <span class="page"/> / <span class="topage"/>
                        </div>
                    </div>
                </div>
            </t>
            <t t-set="fiscal_bond" t-value="o.journal_id.l10n_ar_afip_pos_system in ['BFERCEL', 'BFEWS']"/>

        </t>

        <!-- remove default partner address -->
        <t t-set="address" position="replace"/>
        <xpath expr="//div[@name='address_not_same_as_shipping']" position="replace">
            <div name="address_not_same_as_shipping"/>
        </xpath>
        <xpath expr="//div[@name='address_same_as_shipping']" position="replace">
            <div name="address_same_as_shipping"/>
        </xpath>
        <xpath expr="//div[@name='no_shipping']" position="replace">
            <div name="no_shipping"/>
        </xpath>

        <!-- remove default document title -->
        <xpath expr="//t[@t-set='layout_document_title']" position="replace"/>

        <!-- remove detail of taxes when currency != from company's currency -->
        <t t-call="account.document_tax_totals_company_currency_template" position="replace"/>

        <!-- NCM column for fiscal bond -->
        <th name="th_description" position="after">
            <th t-if="fiscal_bond" name="th_ncm_code" class="text-start"><span>NCM</span></th>
        </th>
        <td name="account_invoice_line_name" position="after">
            <td t-if="fiscal_bond" name="ncm_code"><span t-field="line.product_id.l10n_ar_ncm_code"/></td>
        </td>

        <!-- use latam prices (to include/exclude VAT) -->
        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" position="before">
            <t t-set="l10n_ar_values" t-value="line._l10n_ar_prices_and_taxes()"/>
        </t>
        <xpath expr="//span[@t-field='line.price_unit']" position="attributes">
            <attribute name="t-field"/>
            <attribute name="t-out">l10n_ar_values['price_unit']</attribute>
            <attribute name="t-options">{"widget": "float", "display_currency": o.currency_id, "decimal_precision": "Product Price"}</attribute>
        </xpath>
        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" position="attributes">
            <attribute name="t-value">current_subtotal + l10n_ar_values['price_subtotal']</attribute>
        </t>
        <!-- if b2c we still wants the latam subtotal -->
        <t t-set="current_total" t-value="current_total + line.price_total" position="attributes">
            <attribute name="t-value">current_subtotal + l10n_ar_values['price_subtotal']</attribute>
        </t>
        <!-- label amount for subtotal column on b2b and b2c -->
        <xpath expr="//th[@name='th_subtotal']/span" position="replace">
            <span>Amount</span>
        </xpath>
        <span t-field="line.price_subtotal" position="attributes">
            <attribute name="t-field"/>
            <attribute name="t-out">l10n_ar_values['price_subtotal']</attribute>
            <attribute name="t-options">{"widget": "monetary", "display_currency": o.currency_id}</attribute>
        </span>

        <t t-set="tax_totals" position="attributes">
            <attribute name="t-value">o._l10n_ar_get_invoice_totals_for_report()</attribute>
        </t>

        <!-- use column vat instead of taxes and only if vat discriminated -->
        <xpath expr="//th[@name='th_taxes']" position="replace">
            <th name="th_taxes" t-attf-class="text-start {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" t-if="not o._l10n_ar_include_vat()">
                <span t-if="o.company_id.country_id.code == 'AR'">% VAT</span>
                <span t-else="">Taxes</span>
            </th>
        </xpath>

        <xpath expr="//span[@id='line_tax_ids']/.." position="attributes">
            <attribute name="t-if">not o._l10n_ar_include_vat()</attribute>
        </xpath>
        <span id="line_tax_ids" position="attributes">
            <attribute name="t-out">', '.join(map(lambda x: (x.invoice_label or x.name), line.tax_ids.filtered(lambda x: x.tax_group_id.l10n_ar_vat_afip_code)))</attribute>
        </span>

        <!-- remove payment reference that is not used in Argentina -->
        <xpath expr="//span[@t-field='o.payment_reference']/../.." position="replace"/>

        <!-- replace information section and usage argentinean style -->
        <div id="informations" position="replace">
            <div id="informations" class="row" style="font-family:sans-serif; border: 1px solid black;">
                <div class="col-6 p-3">

                    <strong>Señor(es):  </strong> <span t-field="o.partner_id.commercial_partner_id.name"/>

                    <br/>

                    <strong>Domicilio:  </strong> <span t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': true, 'no_tag_br': True}"/>

                    <br/>

                    <strong>Moneda: </strong> <span t-field="o.currency_id.currency_unit_label"/>

                </div>
                <div class="col-6 p-3">
                    <div class="row">
                        <div class="col text-start">
                            <span t-field="o.partner_id.internal_code"/>
                        </div>
                        <div class="col text-start">
                            <strong><span>N° Identif.:  </span></strong> <span t-field="o.partner_id.num_identificacion"/>
                        </div>
                    </div>

                    <div class="row" style="margin-top:30px;">
                        <div class="col-8 text-start">
                            <!-- (17) CUIT -->
                            <t t-if="o.partner_id.vat and o.partner_id.l10n_latam_identification_type_id">
                                <strong><t t-out="o.partner_id.l10n_latam_identification_type_id.name or o.company_id.account_fiscal_country_id.vat_label" id="inv_tax_id_label"/>:</strong> <span t-out="o.partner_id.l10n_ar_formatted_vat if o.partner_id.l10n_ar_vat else o.partner_id.vat"/>
                            </t>
                        </div>
                        <div class="col-4 text-start">
                            <span t-field="o.partner_id.l10n_ar_afip_responsibility_type_id"/>
                        </div>
                    </div>

                    <t t-if="o.ref">
                        <br/><strong>O.Compra:</strong>
                        <span t-field="o.ref"/>
                    </t>

                </div>
            </div>
            <div class="row mt-0 px-3 py-0" style="border: 1px solid black; border-top: none;">
                <div class="col-6">
                    <strong>Forma de pago: </strong><span t-field="o.invoice_payment_term_id.name"/>
                </div>
                <div class="col-6">
                    <strong>Fecha de vencimiento: </strong> <span t-field="o.invoice_date_due"/>
                </div>
            </div>
        </div>


        <!-- Show total amount in letters for MiPyMEs document types according to the law
         http://biblioteca.afip.gob.ar/dcp/LEY_C_027440_2018_05_09 article 5.f -->
        <xpath expr="//div[@id='total']/div/table" position="after">
            <t t-if="o.l10n_latam_document_type_id.code in ['201', '202', '203', '206', '207', '208', '211', '212', '213']">
                <strong>Son: </strong><span t-out="o.currency_id.with_context(lang='es_AR').amount_to_text(o.amount_total)"/>
            </t>
        </xpath>

        <!-- RG 5003: Add legend for 'A' documents that have a Monotribuista receptor -->
        <div name="comment" position="after">
            <p t-if="o.partner_id.l10n_ar_afip_responsibility_type_id.code in ['6', '13'] and o.l10n_latam_document_type_id.l10n_ar_letter == 'A'">
                The tax credit specified in this voucher may only be computed for purposes of the Tax Support and Inclusion Regime for Small Taxpayers of Law No. 27,618.
            </p>
        </div>

        <t t-call="account.document_tax_totals" position="attributes">
            <attribute name="t-call">l10n_ar.document_tax_totals</attribute>
        </t>

        <div id="qrcode" position="after">
            <!-- RG 5614/2024: Show ARCA VAT and Other National Internal Taxes -->
            <t t-set="l10n_ar_custom_tax_summary" t-value="o._l10n_ar_get_invoice_custom_tax_summary_for_report()"/>
            <div class="l10n_ar_tax_details" t-if="l10n_ar_custom_tax_summary">
                <table class="table table-sm table-borderless" style="page-break-inside: avoid;">
                    <th class="border-black" style="border-bottom: 1px solid" colspan="2">
                           Fiscal Transparency Regime for the Final Consumer (Law 27.743)
                    </th>
                    <t t-foreach="l10n_ar_custom_tax_summary" t-as="detail">
                        <tr>
                            <td class="text-end"><strong t-esc="detail['name']"/></td>
                            <td class="text-end">
                                <span class="oe_subtotal_footer_separator" t-out="detail['formatted_tax_amount_currency']"/>
                            </td>
                        </tr>
                    </t>
                </table>
            </div>
        </div>

        <xpath expr="." position="attributes">
            <attribute name="t-name">l10n_ar.report_invoice_document</attribute>
        </xpath>

        <xpath expr="//div[@class='oe_structure'][1]" position="replace"/>

        <xpath expr="//table[@name='invoice_line_table']" position="replace">
            <table class="table o_main_table table-borderless " name="invoice_line_table">
                <thead style="border: 1px solid black; border-top: none;">
                    <tr>
                        <th name="th_remito" class="text-start px-3 py-1"><span>REMITO</span></th>
                        <th name="th_code" class="text-start px-3 py-1"><span>CODIGO</span></th>
                        <th name="th_description" class="text-start px-3 py-1"><span>DESCRIPCION</span></th>
                        <th name="th_quantity" class="text-end px-3 py-1"><span>CANTIDAD</span></th>
                        <th name="th_priceunit" t-attf-class="text-end px-3 py-1 text-nowrap {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>PRECIO</span></th>
    <!--                    <th name="th_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">-->
    <!--                        <span>Disc.%</span>-->
    <!--                    </th>-->
    <!--                    <th name="th_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Taxes</span></th>-->
                        <th name="th_subtotal" class="text-end px-3 py-1">
                            <span>IMPORTE</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="invoice_tbody px-3 py-1">
                    <t t-set="current_subtotal" t-value="0"/>
                    <t t-set="current_total" t-value="0"/>
                    <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>

                    <t t-foreach="lines" t-as="line">
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>
                        <t t-set="current_total" t-value="current_total + line.price_total"/>

                        <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''"  style="line-height: 1;">
                            <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">
                                <td name="td_remito" class="px-3 py-1">
    <!--                                <span t-if="line.product_id" t-field="line.product_id.default_code"/>-->
                                    <span t-field="line.remito" style="font-size:14px;"/>
                                </td>
                                <td name="td_code" class="px-3 py-1">
                                    <span t-if="line.product_id" t-field="line.product_id.default_code" style="font-size:14px;"/>
                                </td>
                                <td name="account_invoice_line_name" class="px-3 py-1">
                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}" style="font-size:14px;">Bacon Burger</span>
                                </td>
                                <td name="td_quantity" class="text-end px-3 py-1 text-nowrap">
                                    <span t-field="line.quantity" style="font-size:14px;">3.00</span>
                                    <span t-field="line.product_uom_id" groups="uom.group_uom" style="font-size:14px;">units</span>
                                </td>
                                <td name="td_price_unit" t-attf-class="text-end px-3 py-1 {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                    <span class="text-nowrap" t-field="line.price_unit" style="font-size:14px;">9.00</span>
                                </td>
    <!--                            <td name="td_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">-->
    <!--                                <span class="text-nowrap" t-field="line.discount">0</span>-->
    <!--                            </td>-->
                                <t t-set="taxes" t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
    <!--                            <td name="td_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">-->
    <!--                                <span t-out="taxes" id="line_tax_ids">Tax 15%</span>-->
    <!--                            </td>-->
                                <td name="td_subtotal" class="text-end o_price_total px-3 py-1">
                                    <span class="text-nowrap" t-field="line.price_subtotal" style="font-size:14px;">27.00</span>
                                </td>
                            </t>
                            <t t-elif="line.display_type == 'line_section'">
                                <td colspan="99">
                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">A section title</span>
                                </td>
                                <t t-set="current_section" t-value="line"/>
                                <t t-set="current_subtotal" t-value="0"/>
                            </t>
                            <t t-elif="line.display_type == 'line_note'">
                                <td colspan="99">
                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">A note, whose content usually applies to the section or product above.</span>
                                </td>
                            </t>
                        </tr>

                        <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                            <tr class="is-subtotal text-end">
                                <td colspan="99">
                                    <strong class="mr16">Subtotal</strong>
                                    <span t-out="current_subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}">31.05</span>
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>
        </xpath>

        <xpath expr="//div[@id='total']/div" position="replace"/>
        <xpath expr="//div[@name='comment']" position="replace">
            <div name="comment"/>
        </xpath>

        <xpath expr="//span[@id='payment_terms_note_id']" position="replace"/>

    </template>

    <template id="l10n_ar_stock.report_invoice_document" inherit_id="l10n_ar.report_invoice_document">
        <div name="comment" position="after">
            <p t-if="any(x.sudo().lot_id.dispatch_number for x in o.mapped('invoice_line_ids.move_line_ids.move_line_ids'))" name="dispach">
                <span t-out="'Despachos Involucrados: ' + ', '.join(o.mapped('invoice_line_ids.move_line_ids.move_line_ids.lot_id').filtered('dispatch_number').mapped('dispatch_number'))"/>
            </p>
        </div>
    </template>

</odoo>

