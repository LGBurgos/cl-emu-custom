<odoo>
    <!-- HEADER -->
    <template id="custom_header_delivery">
        <style>
            .only-bottom {
                border-bottom: 1px solid;
                border-top: none;
                border-left: none;
                border-right: none;
            }
            .only-right {
                border-bottom: none;
                border-top: none;
                border-left: none;
                border-right: 1px solid black;
            }
        </style>

        <div style="border-color: black !important; border: 1px solid;">
            <div class="row" style="position: relative;">
                <div class="col-6 only-right">
                    <div class="row border-top-0" style="font-family:sans-serif">
                        <div class="col-3">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" class="m-2 p-2" alt="Logo" style="width:100px;"/>
                        </div>
                        <div class="col-8 text-start" style="color: black !important;">
                            <strong><div t-field="o.company_id.company_details"/></strong>
                        </div>
                    </div>
                </div>
                <div class="col border-top-0" style="position: absolute; left: 46.75%; background-color: white; top: 1px; width: 62px; height: 64px; border-color: black !important; border: 1px solid;">
                    <table name="hito-center-upper" class="table-borderless" style="text-align: center; margin: auto;">
                        <tr>
                            <td>
                                <h2 style="margin-top:10px !important; color: black;">
                                    <strong><span t-out="document_letter or '&#160;'"/></strong>
                                </h2>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col text-center" style="position: absolute; left: 46.75%; background-color: white; top: 100px; width: 62px; height: 46px;">
                    <tr>
                        <td>
                            <span style="font-size: 8px;" t-out="document_legend or '&#160;'"/>
                        </td>
                    </tr>
                </div>

                <div class="col-6" style="margin-left:50px; text-align: start; font-family:sans-serif;">
                    <span t-field="o.document_type_id.name" style="font-weight:bold; font-size: 22px;"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Remito Nº: </span> <span t-field="o.vouchers"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Fecha: </span><span t-field="o.date_done"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">CUIT: </span><span t-field="o.company_id.vat"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Ingresos Brutos: </span><span t-out="o.company_id.l10n_ar_gross_income_type == 'exempt' and 'Exento' or o.company_id.l10n_ar_gross_income_number"/>
                    <br/>
                    <span style="font-weight:bold; font-size: 18px;">Fecha de Inicio de Actividades: </span><span t-field="o.company_id.l10n_ar_afip_start_date"/>
                </div>
            </div>
        </div>

    </template>


    <template id="l10n_ar_stock.report_delivery_document" inherit_id="stock.report_delivery_document">
        <!-- custom header and footer -->
        <t t-set="o" position="after">
            <t t-set="custom_header" t-value="'hito_emu_custom_reports.custom_header_delivery'"/>
            <t t-set="report_date" t-value="o.date_done"/>
            <t t-set="report_number" t-value="o.vouchers or o.name"/>
            <t t-set="pre_printed_report" t-value="o.book_id.lines_per_voucher"/>
            <t t-set="document_letter" t-value="o.document_type_id.l10n_ar_letter or 'X'"/>
            <t t-set="document_legend" t-value="'Doc. no válido como factura'"/>
            <t t-set="report_name" t-value="o.document_type_id.report_name or 'Comprobante de Entrega'"/>
            <t t-set="header_address" t-value="o.book_id.report_partner_id or o.picking_type_id.warehouse_id.partner_id or o.company_id.partner_id"/>

            <t t-set="custom_footer">
                <div class="row">
                    <div class="col-6 text-start">
                        <span>Transporte: </span><span t-field="o.transporte"/>
                        <br/>
                        <span>Despachado por: </span> <span t-field="o.despachado_por"/>
                        <br/>
                        <span>Control: </span> <span t-field="o.control"/>
                        <br/>
                        <t t-if="not copy_type">
                            <span>ORIGINAL</span>
                        </t>
                        <t t-else="">
                            <t t-out="copy_type"/>
                        </t>
                    </div>
                    <div class="col-6 text-center">
                        <span>Cajas: </span><span t-field="o.number_of_packages"/>
                        <br/>
                        <span>Kg: </span> <span t-field="o.kg"/>
                        <br/>
                    </div>
                </div>

                <div class="row">
                    <div name="footer_left_column" class="col-8 text-center">
                        <t t-if="o.l10n_ar_afip_barcode">
                            <div style="text-align: center;">
                                <img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.l10n_ar_afip_barcode, 400, 40)" alt="Barcode" style="height:40px; width:100%"/>
                                <br/>
                                <span t-esc="o.l10n_ar_afip_barcode" style="font-size: 14px;"/>
                            </div>
                        </t>
                        <t t-if="o.book_id.report_signature_section and not o.l10n_ar_afip_barcode">
                            <table class="table table-borderless table-sm">
                                <thead>
                                    <tr>
                                        <th width="25%">Recibí conforme:</th>
                                        <th width="25%"/>
                                        <th width="25%"/>
                                        <th width="25%"/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <th style="text-align: center;">____ / ____ / ____</th>
                                        <td>
                                            <hr style="border: 1px solid #000000;"/>
                                        </td>
                                        <td>
                                            <hr style="border: 1px solid #000000;"/>
                                        </td>
                                        <td>
                                            <hr style="border: 1px solid #000000;"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th style="text-align: center;">Fecha</th>
                                        <th style="text-align: center;">DNI</th>
                                        <th style="text-align: center;">Firma</th>
                                        <th style="text-align: center;">Aclaración</th>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                    </div>
                    <div name="footer_right_column" class="col-4 text-right">
                        <div t-if="not o.book_id.lines_per_voucher and o.book_id.l10n_ar_cai">
                            CAI: <span t-field="o.book_id.l10n_ar_cai"/>
                        </div>
                        <div t-if="not o.book_id.lines_per_voucher and o.book_id.l10n_ar_cai_due">
                            CAI Due Date: <span t-field="o.book_id.l10n_ar_cai_due"/>
                        </div>
                        <div name="pager" t-if="report_type == 'pdf'">
                            Page: <span class="page"/>
                            /                        <span class="topage"/>
                        </div>
                    </div>
                </div>
            </t>
        </t>

        <!-- remove default partner address -->
        <t t-set="address" position="attributes">
            <attribute name="t-value">False</attribute>
        </t>
        <t t-set="information_block" position="attributes">
            <attribute name="t-value">False</attribute>
        </t>

        <!-- remove default document title -->
        <h2 position="replace"/>

        <!-- We want to hide order number and shipping address show at to left side of the report -->
        <xpath expr="//div[@name='div_origin']/.." position="attributes">
            <attribute name="id">hide_order_and_shipping_date</attribute>
            <attribute name="t-if">0</attribute>
        </xpath>


        <div id="hide_order_and_shipping_date" position="after">
            <div class="row" style="height:40px;">

            </div>
            <div id="informations" class="row">
                <div class="col-6">
<!--                    <t t-set="partner" t-value="o.partner_id or (o.move_ids and o.move_ids[0].partner_id)"/>-->
<!--                    <t t-set="commercial_partner" t-value="partner.commercial_partner_id"/>-->

                    <!-- IDENTIFICACION (ADQUIRIENTE-LOCATARIO-PRESTARIO) -->

<!--                    &lt;!&ndash; (14) Apellido uy Nombre: Denominicacion o Razon Soclial &ndash;&gt;-->
<!--                    <strong>Customer: </strong>-->
<!--                    <span t-field="commercial_partner.name"/>-->

<!--                    &lt;!&ndash; (15) Domicilio Comercial &ndash;&gt;-->
<!--                    <br/>-->

<!--                    <span t-if="commercial_partner != partner">-->
<!--                        <strong>Deliver to: </strong>-->
<!--                        <span t-field="partner.name"/>-->
<!--                    </span>-->
<!--                    <span t-out="partner" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;phone&quot;, &quot;mobile&quot;], &quot;no_marker&quot;: False}"/>-->
                    <strong>Sr.(es):</strong> <span t-field="o.partner_id.name"/>
                    <br/>

                    <strong>Domicilio:  </strong> <span t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': true, 'no_tag_br': True}"/>

                    <br/>

                    <strong>Forma de pago: </strong> <span t-field="o.payment_terms"/>

                </div>
                <div class="col-6">
                    <t>
                        <strong>C.U.I.T:</strong>
                        <span t-field="o.partner_id.vat"/>
                        <br/>
                    </t>

                    <t>
                        <strong>IVA: </strong>
                        <span t-field="partner.l10n_ar_afip_responsibility_type_id"/>
                        <br/>
                    </t>

                     <t>
                        <strong>Orden de compra:</strong>
                        <span t-field="o.orden_compra"/>
                        <br/>
                    </t>

                    <t>
                        <strong>Nº pedido:</strong>
                        <span t-field="o.sale_id.name"/>
                        <br/>
                    </t>

                    <t position="after">
                        <t t-if="o.cot">
                            <br/>
                            <strong>COT:</strong>
                            <span t-field="o.cot"/>
                        </t>
                    </t>
                    <t t-if="o._fields.get('purchase_order_number') and o.sudo().purchase_order_number">
                        <br/>
                        <strong>Número OC:</strong>
                        <span t-field="o.sudo().purchase_order_number"/>
                    </t>

<!--                    <t t-if="o.declared_value">-->
<!--                        <br/>-->
<!--                        <strong>Valor declarado:</strong>-->
<!--                        <span t-field="o.declared_value"/>-->
<!--                    </t>-->
<!--                    <t t-if="o.number_of_packages">-->
<!--                        <br/>-->
<!--                        <strong>Cant. de paquetes:</strong>-->
<!--                        <span t-field="o.number_of_packages"/>-->
<!--                    </t>-->
                </div>

            </div>
        </div>

        <table name="stock_move_line_table" position="after">
            <t t-if="o.book_id.report_signature_section and o.l10n_ar_afip_barcode">
                <table class="table table-borderless table-sm">
                    <thead>
                        <tr>
                            <th width="25%">Recibí conforme:</th>
                            <th width="25%"/>
                            <th width="25%"/>
                            <th width="25%"/>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th width="25%">Fecha: ____ / ____ / ____</th>
                            <td>
                                <hr style="border: 1px solid #000000;"/>
                            </td>
                            <td>
                                <hr style="border: 1px solid #000000;"/>
                            </td>
                            <td>
                                <hr style="border: 1px solid #000000;"/>
                            </td>
                        </tr>
                        <tr>
                            <td/>
                            <th style="text-align: center;">DNI</th>
                            <th style="text-align: center;">Firma</th>
                            <th style="text-align: center;">Aclaración</th>
                        </tr>
                    </tbody>
                </table>
            </t>
        </table>

        <xpath expr="//table[@name='stock_move_line_table']" position="replace">
            <table class="table table-borderless mt48" t-elif="o.move_line_ids and o.state=='done'" name="stock_move_line_table">
                <thead style="border-top: 2px solid black; border-bottom: 2px solid black;">
                    <th class="p-1">
                        <span>CODIGO</span>
                    </th>
                    <th class="p-1">
                        <span>DESCRIPCION</span>
                    </th>
                     <th class="p-1">
                        <span>CANTIDAD</span>
                    </th>
                </thead>
                <tbody>
                    <t t-foreach="o.move_line_ids" t-as="line">
                        <tr>
                            <td class="p-2">
                                <span t-esc="line.product_id.default_code"/>
                            </td>
                            <td class="p-2">
                                <span t-esc="line.product_id.name"/>
                            </td>
                            <td class="p-2">
                                <span t-esc="line.quantity"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </xpath>



    </template>



