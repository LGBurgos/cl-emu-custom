<odoo>
    <record id="view_partner_form_inherit_num_identificacion" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.num.identificacion</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='internal_code']" position="after">
                <field name="num_identificacion"/>
            </xpath>

        </field>
    </record>
</odoo>