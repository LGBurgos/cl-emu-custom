<odoo>
    <!-- Vista Tree/List -->
    <record id="view_transporte_tree" model="ir.ui.view">
        <field name="name">transporte.tree</field>
        <field name="model">transporte</field>
        <field name="arch" type="xml">
            <list string="Transportes">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_transporte_form" model="ir.ui.view">
        <field name="name">transporte.form</field>
        <field name="model">transporte</field>
        <field name="arch" type="xml">
            <form string="Transporte">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Search -->
    <record id="view_transporte_search" model="ir.ui.view">
        <field name="name">transporte.search</field>
        <field name="model">transporte</field>
        <field name="arch" type="xml">
            <search string="Buscar Transporte">
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- Acción para abrir vistas -->
    <record id="action_transporte" model="ir.actions.act_window">
        <field name="name">Transportes</field>
        <field name="res_model">transporte</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_transporte" name="Transportes" parent="stock.menu_stock_config_settings" action="action_transporte"/>
</odoo>