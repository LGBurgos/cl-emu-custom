<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="emu_account_bank_statement_notes.BankRecManualOpsExtension"
       t-inherit="account_accountant.BankRecRecordNotebookManualOperations"
       t-inherit-mode="extension">

        <!-- Agregar statement_note_id después de narration -->
        <xpath expr="//div[@name='narration']" position="after">
            <div name="statement_note_id"
                 t-if="line.data.flag === 'liquidity' and line.fields.statement_note_id"
                 class="o_wrap_field d-flex d-sm-contents flex-column">
                <div class="o_cell o_wrap_label flex-grow-1 flex-sm-grow-0 w-100 text-break text-900">
                    <label class="o_form_label" t-att-class="{'o_form_label_readonly': reconciled}">
                        Nota de extracto
                    </label>
                </div>
                <div class="o_cell o_wrap_input flex-grow-1 flex-sm-grow-0 w-100">
                    <div class="o_field_widget o_field_many2one">
                        <Many2OneField
                            name="'statement_note_id'"
                            record="line"
                            readonly="reconciled"
                            canOpen="true"
                            canQuickCreate="true"
                        />
                    </div>
                </div>
            </div>
        </xpath>

    </t>

</templates>