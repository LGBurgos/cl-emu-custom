<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista heredada del formulario de línea de extracto bancario -->
    <record id="view_account_bank_statement_line_form_inherited" model="ir.ui.view">
        <field name="name">account.bank.statement.line.form.inherited</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_form_bank_rec_widget"/>
        <field name="arch" type="xml">
            <xpath expr="//footer" position="before">
                <separator string="Nota de Extracto Bancario"/>
                <group>
                    <field name="statement_note_id" />
                </group>
            </xpath>
        </field>
    </record>

    <!-- Vista heredada de la lista -->
    <record id="view_account_bank_statement_line_tree_inherited" model="ir.ui.view">
        <field name="name">account.bank.statement.line.tree.inherited</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_tree_bank_rec_widget"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="before">
                <field name="statement_note_id" />
            </xpath>
        </field>
    </record>

</odoo>