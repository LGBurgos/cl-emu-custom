<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista heredada del formulario de línea de extracto bancario -->
    <record id="view_account_bank_statement_line_form_inherited" model="ir.ui.view">
        <field name="name">account.bank.statement.line.form.inherited</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account.view_bank_statement_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='narration']" position="after">
                <field name="statement_note_id" />
            </xpath>
        </field>
    </record>

</odoo>
