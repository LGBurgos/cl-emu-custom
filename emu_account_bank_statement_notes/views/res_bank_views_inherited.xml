<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extender la vista de formulario del banco -->
    <record id="view_res_bank_form_inherited" model="ir.ui.view">
        <field name="name">res.bank.form.inherited</field>
        <field name="model">res.bank</field>
        <field name="inherit_id" ref="base.view_bank_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Notas de Extractos Bancarios" name="statement_notes">
                    <group>
                        <field name="default_statement_note_id" />
                    </group>
                    <separator string="Documentación" />
                    <group>
                        <field name="notes_for_statements" nolabel="1" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
