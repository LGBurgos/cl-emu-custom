<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Etiqueta debajo de Referencia -->
  <record id="view_move_form_inherit_emu_label" model="ir.ui.view">
    <field name="name">account.move.form.inherit.emu.label</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet//field[@name='ref']" position="after">
        <newline/>
        <field name="etiqueta_id" string="Etiqueta"/>
      </xpath>

      <xpath expr="//field[@name='line_ids']/list/field[@name='name']" position="attributes">
        <attribute name="string">Observación</attribute>
      </xpath> 
        
    </field>
  </record>
</odoo>
