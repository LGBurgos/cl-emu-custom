<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- SHIM: envolver currency_id en div name="currency_div" para que el xpath de Studio exista -->
  <record id="view_move_form_fix_currency_div" model="ir.ui.view">
    <field name="name">account.move.form.fix.currency.div</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <!-- Prioridad baja para aplicar primero -->
    <field name="priority">0</field>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='currency_id']" position="replace">
        <div name="currency_div">
          <field name="currency_id"/>
        </div>
      </xpath>
    </field>
  </record>

  <!-- Etiqueta arriba y Referencia abajo -->
  <record id="view_move_form_inherit_emu_label" model="ir.ui.view">
    <field name="name">account.move.form.inherit.emu.label</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="priority">99</field>
    <field name="arch" type="xml">
      <!-- Inserto etiqueta ANTES de ref para que ref quede debajo -->
      <xpath expr="//sheet//field[@name='ref']" position="before">
        <field name="etiqueta_id" string="Etiqueta"/>
      </xpath>
    </field>
  </record>

</odoo>
