<odoo>
  <!-- Agregar campo debajo de Referencia -->
  <record id="view_move_form_inherit_emu_label" model="ir.ui.view">
    <field name="name">account.move.form.inherit.emu.label</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='ref']" position="after">
        <field name="etiqueta_id"/>
      </xpath>

      <!-- 2) Renombrar columna 'Etiqueta' de las líneas a 'Observación' -->
      <xpath expr="//field[@name='line_ids']//tree//field[@name='name']" position="attributes">
        <attribute name="string">Observación</attribute>
      </xpath>
      <!-- si hay vista formulario de línea embebida, renombrar también -->
      <xpath expr="//field[@name='line_ids']//form//field[@name='name']" position="attributes">
        <attribute name="string">Observación</attribute>
      </xpath>
    </field>
  </record>
</odoo>
