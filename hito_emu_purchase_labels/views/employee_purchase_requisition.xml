<odoo>
    <record id="employee_purchase_requisition_view_form_inherit_custom" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.view.form.inherit.custom</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='company_id']" position="after">
                <field name="requisition_purchase_label_id"/>
            </xpath>

        </field>
    </record>

    <record id="employee_purchase_requisition_view_tree_inherit_custom" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.view.tree.inherit.custom</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='dept_id']" position="after">
                <field name="requisition_purchase_label_id" widget="badge"/>
            </xpath>

        </field>
    </record>

    <record id="employee_purchase_requisition_view_search_inherit_custom" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.view.search.inherit.custom</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_search"/>
        <field name="arch" type="xml">

            <xpath expr="//filter[@name='dept_id']" position="after">

                <filter string="Etiqueta de Requisición"
                        name="filter_requisition_purchase_label"
                        domain="[('requisition_purchase_label_id','!=',False)]"/>

                <filter string="Etiqueta de Requisición"
                        name="group_requisition_purchase_label"
                        context="{'group_by':'requisition_purchase_label_id'}"/>
            </xpath>

        </field>
    </record>

</odoo>