<odoo>
    <record id="action_purchase_label" model="ir.actions.act_window">
        <field name="name">Etiquetas de Compra</field>
        <field name="res_model">purchase.label</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="view_purchase_label_tree" model="ir.ui.view">
        <field name="name">purchase.label.tree</field>
        <field name="model">purchase.label</field>
        <field name="arch" type="xml">
            <list string="Etiquetas de Compra">
                <field name="name"/>
            </list>
        </field>
    </record>


    <record id="view_purchase_label_form" model="ir.ui.view">
        <field name="name">purchase.label.form</field>
        <field name="model">purchase.label</field>
        <field name="arch" type="xml">
            <form string="Etiqueta de Compra">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <menuitem id="menu_purchase_label_config"
              name="Etiquetas de Compra"
              parent="purchase.menu_purchase_config"
              action="action_purchase_label"
              sequence="50"/>
</odoo>