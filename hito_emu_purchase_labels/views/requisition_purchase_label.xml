<odoo>
    <record id="action_requisition_purchase_label" model="ir.actions.act_window">
        <field name="name">Etiquetas de Requisición</field>
        <field name="res_model">requisition.purchase.label</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="view_requisition_purchase_label_tree" model="ir.ui.view">
        <field name="name">requisition.purchase.label.tree</field>
        <field name="model">requisition.purchase.label</field>
        <field name="arch" type="xml">
            <list string="Etiquetas de Requisición">
                <field name="name"/>
            </list>
        </field>
    </record>


    <record id="view_requisition_purchase_label_form" model="ir.ui.view">
        <field name="name">requisition.purchase.label.form</field>
        <field name="model">requisition.purchase.label</field>
        <field name="arch" type="xml">
            <form string="Etiqueta de Requisición">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <menuitem id="menu_request_purchase_label_config"
              name="Etiquetas de Requisicion"
              parent="purchase_request.parent_menu_purchase_request"
              action="action_requisition_purchase_label"
              sequence="50"/>
</odoo>