<odoo>
  <!-- Plantilla: OC estándar + página nueva con T&C -->
  <template id="report_purchaseorder_with_terms_document">
    <t t-call="purchase.report_purchaseorder_document"/>
    <t t-foreach="docs" t-as="o">
      <t t-if="o.company_id.purchase_terms">
        <t t-call="web.external_layout">
          <div class="page">
            <h2>Términos y condiciones</h2>
            <div t-raw="o.company_id.purchase_terms"/>
          </div>
        </t>
      </t>
    </t>
  </template>

  <!-- Acción para menú Imprimir -->
  <report
      id="action_report_purchaseorder_with_terms"
      model="purchase.order"
      string="Orden de compra con términos y condiciones"
      report_type="qweb-pdf"
      name="emu_purchase_terms.report_purchaseorder_with_terms_document"
      print_report_name="'PO_%s_TyC' % (object.name)"/>
</odoo>
