<odoo>
  <record id="purchase_res_config_settings_view_form_inherit_terms" model="ir.ui.view">
    <field name="name">purchase.res.config.settings.terms</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="purchase.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@id='purchase_settings']" position="inside">
        <div class="settings">
          <h2>Órdenes • Términos y condiciones</h2>
          <div class="row mt16 o_setting_box">
            <div class="col-12">
              <label for="purchase_terms"/>
              <field name="purchase_terms"
                     placeholder="Escriba los T&amp;C para imprimir en OC..."/>
              <div class="text-muted">Se imprimen en una hoja aparte.</div>
            </div>
          </div>
        </div>
      </xpath>
    </field>
  </record>
</odoo>
