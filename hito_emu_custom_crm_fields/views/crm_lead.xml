<odoo>
    <record id="view_crm_lead_form_inherit_custom" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form[1]/sheet[1]/group[1]/group[@name='opportunity_partner']/div[2]" position="after">
                <field name="recepcion_rfq" widget="datetime" options="{'show_seconds':false,'show_time':false}"/>
                <field name="envio_rfq" widget="datetime" options="{'show_seconds':false,'show_time':false}"/>
                <field name="lead_time"/>
            </xpath>

            <xpath expr="//form[1]/sheet[1]/group[1]/group[not(@name)][1]/field[@name='tag_ids']" position="after">
                <field name="cotizacion" options="{'step':1}"/>
<!--                <field name="rubro" options="{'create_name_field': 'x_name'}"/>-->
<!--                <field name="tipo_de_pieza" options="{'create_name_field': 'x_name'}"/>-->
            </xpath>

        </field>
    </record>
</odoo>